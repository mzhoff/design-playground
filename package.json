{
  "name": "design-playground",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "lint:root": "biome check .",
    "lint:root:fix": "biome check --write .",
    "typecheck": "turbo typecheck",
    "playground:dev": "pnpm --filter @gigonom/playground dev",
    "docs:dev": "pnpm --filter @gigonom/docs dev",
    "storybook": "pnpm --filter @gigonom/storybook storybook",
    "docs:check": "sherif && pnpm lint:root",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "lefthook": "^2.0.4",
    "sherif": "^1.11.1",
    "turbo": "^2.6.1",
    "typescript": "5.9.3"
  }
}
