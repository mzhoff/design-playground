{
  "name": "design-playground",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint && pnpm run lint:root",
    "lint:fix": "turbo run lint:fix && pnpm run lint:root:fix",
    "lint:root": "biome check .",
    "lint:root:fix": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "docs:check": "biome check docs README.md",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "lefthook": "^2.0.4",
    "sherif": "^1.11.1",
    "turbo": "^2.6.1",
    "typescript": "5.9.3"
  }
}
